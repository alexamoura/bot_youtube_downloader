# Telegram
TELEGRAM_BOT_TOKEN=

# Deixe WEBHOOK_URL vazio para rodar em modo long-polling (sem domínio/HTTPS público).
# Só preencha se for expor a VM publicamente com um domínio + TLS e voltar a usar webhook.
WEBHOOK_URL=

# Mercado Pago (opcional, necessário só para o plano premium via PIX)
MERCADOPAGO_ACCESS_TOKEN=
PREMIUM_PRICE=9.90
PREMIUM_DURATION_DAYS=30

# Groq (opcional, necessário só para /ai e /buscar)
GROQ_API_KEY=

# Alertas no Discord (opcional)
DISCORD_WEBHOOK_URL=

# Cookies em base64 (opcional, conforme necessidade de cada extractor)
YT_COOKIES_B64=
SHOPEE_COOKIES_B64=
IG_COOKIES_B64=

# Keepalive/watchdog só fazem sentido em modo webhook (Render); em polling numa VM sempre-ativa, desligue.
KEEPALIVE_ENABLED=false
